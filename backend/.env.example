# ── Backend Environment Variables ────────────────────────────────────────────
# Copy to .env and fill in your values.

# Firebase Admin SDK — download from Firebase Console → Service Accounts
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
# OR in production on Render, paste the JSON content as a single-line string:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# HuggingFace API token (for AI summaries — Phase 5)
HUGGINGFACE_API_TOKEN=hf_your_token_here

# Anthropic API key (optional — alternative to HuggingFace for AI summaries)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Environment
ENVIRONMENT=development
